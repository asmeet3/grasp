# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub Repository ─────────────────────────────────────
GITHUB_REPO_PATH=./knowledge_repo
GITHUB_REMOTE_URL=https://github.com/your-org/your-knowledge-repo.git
GITHUB_PAT=ghp_...

# ── Confluence ────────────────────────────────────────────
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=your-email@company.com
CONFLUENCE_API_TOKEN=your-confluence-api-token

# ── Jira ──────────────────────────────────────────────────
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# ── SharePoint (Microsoft Graph) ─────────────────────────
SHAREPOINT_TENANT_ID=your-azure-tenant-id
SHAREPOINT_CLIENT_ID=your-azure-app-client-id
SHAREPOINT_CLIENT_SECRET=your-azure-app-client-secret
SHAREPOINT_SITE_ID=your-tenant.sharepoint.com,site-guid,web-guid

# ── Slack ─────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...

# ── Notion ────────────────────────────────────────────────
NOTION_API_KEY=ntn_...

# ── Sync Schedule ─────────────────────────────────────────
SYNC_CRON_HOURS=[2,5,8,11,14]
SYNC_CRON_MINUTE=0
SYNC_BATCH_SIZE=100

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ADMIN_KEY=your-secret-admin-key

# ── Authentication ────────────────────────────────────────
# Google OAuth 2.0 Client ID (leave empty to disable Google sign-in)
GOOGLE_CLIENT_ID=
# Secret for signing session tokens (falls back to ADMIN_KEY if not set)
SESSION_SECRET=